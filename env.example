# Copiar para .env na raiz do projeto (API). Ver também README e QUICKSTART.md.

# URL do frontend (Vite em dev). O Stripe usa isto em success_url / cancel_url.
FRONTEND_URL=http://localhost:5173

# --- Confirmação de encomenda (opcional; sem isto regista-se apenas no log) ---
# Twilio — OTP e SMS de confirmação (número de destino em E.164, ex. +351912345678)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Segredo para hash do código OTP (obrigatório em produção)
OTP_PEPPER=

# SMTP — email após pagamento se o cliente tiver email
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
