# Copiar para .env na raiz do projeto (API). Ver também README e QUICKSTART.md.

# URL do frontend (Vite em dev). O Stripe usa isto em success_url / cancel_url.
FRONTEND_URL=http://localhost:5173

# Segredo para hash do código OTP no checkout na loja (obrigatório em produção)
OTP_PEPPER=

# Email (SMTP) e SMS (Twilio): Admin → Definições da loja → Email e SMS.
# Stripe (chaves, webhook, métodos): Admin → Formas de pagamento → Stripe.

# Postgres (recomendado em produção): ?connect_timeout=10 no DATABASE_URL
