{
    "name": "comebolos-api",
    "version": "1.0.0",
    "description": "Multi-tenant bakery pre-order SaaS backend",
    "main": "dist/server.js",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "start:railway": "prisma migrate deploy && node dist/server.js",
        "postinstall": "prisma generate && patch-package",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate deploy",
        "prisma:migrate:dev": "prisma migrate dev",
        "prisma:seed": "tsx prisma/seed.ts",
        "prisma:studio": "prisma studio"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "prisma": "^5.19.1",
        "@fastify/cors": "^11.2.0",
        "@fastify/jwt": "^10.0.0",
        "@fastify/multipart": "^9.4.0",
        "@fastify/rate-limit": "^10.3.0",
        "@fastify/static": "^9.0.0",
        "@fastify/swagger": "^9.7.0",
        "@fastify/swagger-ui": "^5.2.5",
        "@prisma/client": "^5.19.1",
        "bcryptjs": "^2.4.3",
        "dotenv": "^16.4.5",
        "fastify": "^5.8.2",
        "fastify-plugin": "^5.0.1",
        "luxon": "^3.4.4",
        "nodemailer": "^8.0.5",
        "pino": "^9.3.2",
        "pino-pretty": "^11.2.2",
        "stripe": "^17.3.1",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/luxon": "^3.3.7",
        "@types/node": "^20.14.12",
        "@types/nodemailer": "^8.0.0",
        "patch-package": "^8.0.0",
        "tsx": "^4.16.2",
        "typescript": "^5.5.4"
    },
    "prisma": {
        "seed": "tsx prisma/seed.ts"
    }
}
