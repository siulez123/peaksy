generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  LOJA_ADMIN
}

enum Plan {
  STARTER
  PRO
  PREMIUM
}

enum OrderStatus {
  RECEIVED
  READY
  PICKED_UP
}

enum OrderPaymentMethod {
  ONLINE
  IN_STORE
}

/// Apresentação dos produtos na loja pública.
enum ProductDisplayLayout {
  LARGE
  MEDIUM
  SMALL
}

/// Paleta de cores da loja pública.
enum ShopColorPalette {
  INDIGO
  TEAL
  ROSE
  AMBER
}

enum AnalyticsEventKind {
  PAGE_VIEW
  EMBED_LAND
}

/// Páginas / integrações rastreadas (analytics).
enum AnalyticsPage {
  APEX_HOME
  SHOP
  SHOP_SUCCESS
  SHOP_CANCEL
  PICK_SLUG
  ADMIN_LOGIN
  ADMIN_DASHBOARD
  SUPER_LOGIN
  SUPER_DASHBOARD
  NOT_FOUND
  OTHER
}

model Loja {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  domain    String?  @unique
  timezone  String   @default("Europe/Lisbon")
  active    Boolean  @default(true)
  plan      Plan     @default(STARTER)
  // Morada pública (rodapé da loja)
  addressLine String @default("")
  postalCode  String @default("")
  locality    String @default("")
  phone       String @default("")
  /// Pagamento online (Stripe)
  allowOnlinePayment  Boolean @default(true)
  /// Pagamento no levantamento na loja
  allowInStorePayment Boolean @default(false)
  /// Grelha de produtos na loja pública (grande = predefinido)
  productDisplayLayout ProductDisplayLayout @default(LARGE)
  /// Paleta de cores (loja pública)
  colorPalette       ShopColorPalette       @default(INDIGO)
  /// SMTP por loja (email de confirmação)
  smtpHost           String?
  smtpPort           Int                    @default(587)
  smtpSecure         Boolean                @default(false)
  smtpUser           String?
  smtpPassword       String?
  emailFrom          String?
  /// Twilio por loja (SMS / OTP)
  twilioAccountSid   String?
  twilioAuthToken    String?
  twilioFromNumber   String?
  createdAt DateTime @default(now())

  users            User[]
  vatRates         VatRate[]
  products         Product[]
  availableDays    AvailableDay[]
  orders           Order[]
  productCaps               AvailableDayProductCap[]
  availableDayPickupDates   AvailableDayPickupDate[]
  analyticsEvents           AnalyticsEvent[]
  checkoutVerifications     CheckoutVerification[]

  @@map("lojas")
}

model AnalyticsEvent {
  id        String               @id @default(uuid())
  kind      AnalyticsEventKind
  page      AnalyticsPage
  path      String               @db.VarChar(500)
  lojaId    String?
  /// Variante do código HTML: link, button, iframe
  embedKey  String?              @db.VarChar(32)
  referrer  String?              @db.VarChar(500)
  sessionId String?              @db.VarChar(64)
  createdAt DateTime             @default(now())

  loja Loja? @relation(fields: [lojaId], references: [id], onDelete: SetNull)

  @@index([lojaId, createdAt])
  @@index([page, createdAt])
  @@index([embedKey, createdAt])
  @@map("analytics_events")
}

model User {
  id           String    @id @default(uuid())
  lojaId       String?
  role         UserRole
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())

  loja Loja? @relation(fields: [lojaId], references: [id], onDelete: Cascade)

  @@map("users")
}

model VatRate {
  id          String   @id @default(uuid())
  lojaId      String
  label       String
  ratePercent Decimal  @db.Decimal(5, 2)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  loja     Loja      @relation(fields: [lojaId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([lojaId])
  @@map("vat_rates")
}

model Product {
  id          String   @id @default(uuid())
  lojaId      String
  vatRateId   String
  name        String
  variant     String
  /// Preço com IVA incluído (cêntimos)
  priceCents  Int
  imageUrl    String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  loja                Loja                     @relation(fields: [lojaId], references: [id], onDelete: Cascade)
  vatRate             VatRate                  @relation(fields: [vatRateId], references: [id], onDelete: Restrict)
  orderItems          OrderItem[]
  productCaps         AvailableDayProductCap[]

  @@map("products")
}

model AvailableDay {
  id            String   @id @default(uuid())
  lojaId        String
  /// Primeiro dia de levantamento do período (cache = mínimo das regras)
  pickupDate    DateTime @db.Date
  /// Último dia de levantamento do período (cache = máximo das regras)
  pickupEndDate DateTime @db.Date
  /// A partir de quando os clientes podem encomendar para este período (opcional = sem restrição extra)
  ordersOpenAt  DateTime?
  /// Primeira hora de levantamento permitida (HH:00 ou HH:30)
  pickupTimeMin String   @default("08:00")
  /// Última hora de levantamento permitida (HH:00 ou HH:30)
  pickupTimeMax String   @default("20:00")
  active        Boolean  @default(true)
  /// Máximo de encomendas pagas no período (todas as datas de levantamento deste registo)
  dayCapTotal   Int?
  createdAt     DateTime @default(now())

  loja            Loja                     @relation(fields: [lojaId], references: [id], onDelete: Cascade)
  orders          Order[]
  productCaps     AvailableDayProductCap[]
  pickupDateRules AvailableDayPickupDate[]

  @@index([lojaId, pickupDate])
  @@map("available_days")
}

/// Uma data civil de levantamento com o respetivo limite de encomenda (antes do dia de levantamento).
model AvailableDayPickupDate {
  id             String   @id @default(uuid())
  lojaId         String
  availableDayId String
  pickupDate     DateTime @db.Date
  orderDeadline  DateTime

  loja         Loja         @relation(fields: [lojaId], references: [id], onDelete: Cascade)
  availableDay AvailableDay @relation(fields: [availableDayId], references: [id], onDelete: Cascade)

  @@unique([availableDayId, pickupDate])
  @@index([lojaId, pickupDate])
  @@map("available_day_pickup_dates")
}

model AvailableDayProductCap {
  id             String @id @default(uuid())
  lojaId         String
  availableDayId String
  productId      String
  cap            Int

  loja         Loja         @relation(fields: [lojaId], references: [id], onDelete: Cascade)
  availableDay AvailableDay @relation(fields: [availableDayId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([availableDayId, productId])
  @@map("available_day_product_caps")
}

/// OTP SMS antes de criar encomenda «pagar na loja».
model CheckoutVerification {
  id         String    @id @default(uuid())
  lojaId     String
  phoneE164  String
  codeHash   String
  attempts   Int       @default(0)
  expiresAt  DateTime
  verifiedAt DateTime?
  consumedAt DateTime?
  lastSentAt DateTime  @default(now())
  payload    Json
  createdAt  DateTime  @default(now())

  loja Loja @relation(fields: [lojaId], references: [id], onDelete: Cascade)

  @@index([lojaId, phoneE164, createdAt])
  @@map("checkout_verifications")
}

model Order {
  id              String      @id @default(uuid())
  lojaId          String
  availableDayId  String
  pickupDate      DateTime    @db.Date
  /// Hora de levantamento escolhida (HH:00 ou HH:30)
  pickupTime      String
  customerName    String
  customerPhone   String
  customerEmail   String?
  notes           String?     @db.VarChar(100)
  status          OrderStatus @default(RECEIVED)
  totalCents      Int
  paid            Boolean     @default(false)
  paymentMethod   OrderPaymentMethod @default(ONLINE)
  stripeSessionId String?
  createdAt       DateTime    @default(now())

  loja         Loja         @relation(fields: [lojaId], references: [id], onDelete: Cascade)
  availableDay AvailableDay @relation(fields: [availableDayId], references: [id], onDelete: Cascade)
  items        OrderItem[]

  @@map("orders")
}

model OrderItem {
  id                      String  @id @default(uuid())
  orderId                 String
  productId               String
  productNameSnapshot     String
  variantSnapshot         String
  unitPriceCentsSnapshot  Int
  vatRatePercentSnapshot  Decimal @db.Decimal(5, 2)
  vatRateLabelSnapshot    String
  quantity                Int
  ready                   Boolean @default(false)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("order_items")
}
