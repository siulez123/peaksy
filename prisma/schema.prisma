generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  LOJA_ADMIN @map("BAKERY_ADMIN")
}

enum Plan {
  STARTER
  PRO
  PREMIUM
}

enum OrderStatus {
  RECEIVED
  READY
  PICKED_UP
}

model Loja {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  domain    String?  @unique
  timezone  String   @default("Europe/Lisbon")
  active    Boolean  @default(true)
  plan      Plan     @default(STARTER)
  // Morada pública (rodapé da loja)
  addressLine String @default("")
  postalCode  String @default("")
  locality    String @default("")
  phone       String @default("")
  createdAt DateTime @default(now())

  users            User[]
  products         Product[]
  availableDays    AvailableDay[]
  orders           Order[]
  productCaps               AvailableDayProductCap[]
  availableDayPickupDates   AvailableDayPickupDate[]

  @@map("bakeries")
}

model User {
  id           String    @id @default(uuid())
  lojaId       String?   @map("bakeryId")
  role         UserRole
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())

  loja Loja? @relation(fields: [lojaId], references: [id], onDelete: Cascade)

  @@map("users")
}

model Product {
  id          String   @id @default(uuid())
  lojaId      String   @map("bakeryId")
  name        String
  variant     String
  priceCents  Int
  imageUrl    String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  loja                Loja                     @relation(fields: [lojaId], references: [id], onDelete: Cascade)
  orderItems          OrderItem[]
  productCaps         AvailableDayProductCap[]

  @@map("products")
}

model AvailableDay {
  id            String   @id @default(uuid())
  lojaId        String   @map("bakeryId")
  /// Primeiro dia de levantamento do período (cache = mínimo das regras)
  pickupDate    DateTime @db.Date
  /// Último dia de levantamento do período (cache = máximo das regras)
  pickupEndDate DateTime @db.Date
  /// A partir de quando os clientes podem encomendar para este período (opcional = sem restrição extra)
  ordersOpenAt  DateTime?
  /// Primeira hora de levantamento permitida (HH:00 ou HH:30)
  pickupTimeMin String   @default("08:00")
  /// Última hora de levantamento permitida (HH:00 ou HH:30)
  pickupTimeMax String   @default("20:00")
  active        Boolean  @default(true)
  /// Máximo de encomendas pagas no período (todas as datas de levantamento deste registo)
  dayCapTotal   Int?
  createdAt     DateTime @default(now())

  loja            Loja                     @relation(fields: [lojaId], references: [id], onDelete: Cascade)
  orders          Order[]
  productCaps     AvailableDayProductCap[]
  pickupDateRules AvailableDayPickupDate[]

  @@index([lojaId, pickupDate], map: "available_days_bakeryId_pickupDate_idx")
  @@map("available_days")
}

/// Uma data civil de levantamento com o respetivo limite de encomenda (antes do dia de levantamento).
model AvailableDayPickupDate {
  id             String   @id @default(uuid())
  lojaId         String   @map("bakeryId")
  availableDayId String
  pickupDate     DateTime @db.Date
  orderDeadline  DateTime

  loja         Loja         @relation(fields: [lojaId], references: [id], onDelete: Cascade)
  availableDay AvailableDay @relation(fields: [availableDayId], references: [id], onDelete: Cascade)

  @@unique([availableDayId, pickupDate])
  @@index([lojaId, pickupDate], map: "available_day_pickup_dates_bakeryId_pickupDate_idx")
  @@map("available_day_pickup_dates")
}

model AvailableDayProductCap {
  id             String @id @default(uuid())
  lojaId         String @map("bakeryId")
  availableDayId String
  productId      String
  cap            Int

  loja         Loja         @relation(fields: [lojaId], references: [id], onDelete: Cascade)
  availableDay AvailableDay @relation(fields: [availableDayId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([availableDayId, productId])
  @@map("available_day_product_caps")
}

model Order {
  id              String      @id @default(uuid())
  lojaId          String      @map("bakeryId")
  availableDayId  String
  pickupDate      DateTime    @db.Date
  /// Hora de levantamento escolhida (HH:00 ou HH:30)
  pickupTime      String
  customerName    String
  customerPhone   String
  customerEmail   String?
  notes           String?     @db.VarChar(100)
  status          OrderStatus @default(RECEIVED)
  totalCents      Int
  paid            Boolean     @default(false)
  stripeSessionId String?
  createdAt       DateTime    @default(now())

  loja         Loja         @relation(fields: [lojaId], references: [id], onDelete: Cascade)
  availableDay AvailableDay @relation(fields: [availableDayId], references: [id], onDelete: Cascade)
  items        OrderItem[]

  @@map("orders")
}

model OrderItem {
  id                      String  @id @default(uuid())
  orderId                 String
  productId               String
  productNameSnapshot     String
  variantSnapshot         String
  unitPriceCentsSnapshot  Int
  quantity                Int
  ready                   Boolean @default(false)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("order_items")
}
