# Em desenvolvimento, deixa vazio para usar o proxy do Vite (/api -> http://localhost:3000)
# VITE_API_URL=http://localhost:3000
#
# Em produção (ex. Railway, mesmo domínio que a API): não definir — o cliente usa a mesma origem.
# Só define VITE_API_URL se o frontend estiver noutro host do que a API.

# Domínio principal da plataforma em produção (subdomínios de tenant: {slug}.peaksy.com)
# VITE_APP_DOMAIN=peaksy.com

# Em localhost sem subdomínio, simula um tenant (ex.: lojademo) para a loja na raiz e /admin
# VITE_DEV_TENANT_SLUG=lojademo
